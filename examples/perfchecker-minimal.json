{
  "enabled": true,
  "exclude_paths": [
    "vendor/",
    ".git/",
    "testdata/"
  ],
  "exclude_types": [],
  "severity": {
    "min_level": "medium"
  },
  
  "loop": {
    "enabled": true,
    "check_string_range": false,
    "check_nested_loops": true,
    "max_nested_depth": 3,
    "check_expensive_in_loops": true
  },
  
  "complexity": {
    "enabled": true,
    "max_cyclomatic_depth": 15,
    "max_cognitive_depth": 20,
    "check_recursion": false,
    "max_recursion_depth": 10
  },
  
  "memory": {
    "enabled": true,
    "check_leaks": true,
    "check_allocations": false,
    "max_alloc_per_function": 200,
    "check_map_size": false,
    "check_slice_capacity": false
  },
  
  "context": {
    "enabled": false,
    "check_position": false,
    "check_background_usage": false,
    "check_string_keys": false,
    "check_cancellation": false
  },
  
  "channel": {
    "enabled": false,
    "check_deadlocks": false,
    "check_unbuffered": false,
    "check_multiple_close": false,
    "check_send_on_closed": false,
    "default_buffer_size": 1
  },
  
  "race_condition": {
    "enabled": false,
    "check_shared_variables": false,
    "check_map_access": false,
    "check_slice_append": false,
    "check_global_modification": false
  },
  
  "error_handling": {
    "enabled": true,
    "check_ignored_errors": true,
    "check_unchecked_errors": false,
    "check_error_wrapping": false,
    "check_panic_usage": true,
    "check_error_shadowing": false
  },
  
  "http_client": {
    "enabled": false,
    "check_timeouts": false,
    "default_timeout_sec": 30,
    "check_default_client": false,
    "check_body_close": false,
    "check_connection_limits": false
  },
  
  "database": {
    "enabled": false,
    "check_sql_injection": false,
    "check_n_plus_one": false,
    "check_prepared_stmts": false,
    "check_context_usage": false,
    "max_queries_per_function": 10
  },
  
  "testing": {
    "enabled": false,
    "min_coverage": 50.0,
    "require_benchmarks": false,
    "require_examples": false,
    "check_test_naming": false
  }
}